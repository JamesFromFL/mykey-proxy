[Unit]
Description=WebAuthn Proxy System Tray
After=graphical-session.target webauthn-proxy-daemon.service
Wants=webauthn-proxy-daemon.service

[Service]
Type=simple
ExecStart=/usr/local/bin/webauthn-proxy-tray
Restart=on-failure
RestartSec=3s
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

[Install]
WantedBy=graphical-session.target
